{
  "name": "vaultkeeper-workspace",
  "private": true,
  "description": "Unified, policy-enforced secret storage across OS backends",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "NX_TUI=false nx run-many -t build --exclude=vaultkeeper-workspace",
    "clean": "pnpm -r run clean",
    "test": "NX_TUI=false nx run-many -t test --exclude=vaultkeeper-workspace",
    "test:watch": "vitest",
    "check": "NX_TUI=false nx run-many -t check:typecheck check:lint-ts check:api-report --exclude=vaultkeeper-workspace",
    "check:typecheck": "NX_TUI=false nx run-many -t check:typecheck --exclude=vaultkeeper-workspace",
    "check:lint-ts": "NX_TUI=false nx run-many -t check:lint-ts --exclude=vaultkeeper-workspace",
    "check:api-report": "NX_TUI=false nx run-many -t check:api-report --exclude=vaultkeeper-workspace",
    "generate:api-report": "NX_TUI=false nx run-many -t generate:api-report --exclude=vaultkeeper-workspace",
    "generate:api-docs": "pnpm generate:api-report && node scripts/collect-api-json.mjs && api-documenter markdown -i tmp/api-documenter -o docs/api"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@1password/sdk": "^0.4.0",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.0.0",
    "@microsoft/api-documenter": "^7.29.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-n": "^17.0.0",
    "eslint-plugin-security": "^3.0.0",
    "jiti": "^2.6.1",
    "nx": "^22.5.4",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
