    ],
    "stdin": null,
    "needsConfig": false,
    "expectedExitCode": 0,
    "expectedStdout": {
      "type": "Contains",
      "value": "vaultkeeper"
    },
    "expectedStderr": {
      "type": "Any"
    }
  },
