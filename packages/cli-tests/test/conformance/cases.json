  {
    "name": "help lists all expected commands",
    "command": [
      "--help"
    ],
    "stdin": null,
    "needsConfig": false,
    "expectedExitCode": 0,
    "expectedStdout": {
      "type": "Regex",
      "value": "(?s)exec.*doctor.*approve.*dev-mode.*store.*delete.*config.*rotate-key"
    },
    "expectedStderr": {
      "type": "Any"
    }
  },
  {
