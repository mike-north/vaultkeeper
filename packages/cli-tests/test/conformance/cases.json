    "needsConfig": false,
    "expectedExitCode": 0,
    "expectedStdout": {
      "type": "Contains",
      "value": "vaultkeeper"
    },
    "expectedStderr": {
      "type": "Any"
    }
  },
  {
    "name": "help flag prints help and exits 0",
